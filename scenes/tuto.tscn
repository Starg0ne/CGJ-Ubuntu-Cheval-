[node name="TutoText4" type="Label" parent="Level"]
offset_left = 1655.0
offset_top = 109.0
offset_right = 2051.0
offset_bottom = 184.0
text = "Attention aussi, si tu te fais  toucher par un ennemi
tu perderas une vie !"

[node name="TutoText5" type="Label" parent="Level"]
offset_left = 2520.0
offset_top = 63.0
offset_right = 2916.0
offset_bottom = 164.0
text = "Tu peux aussi passer en mode grappin
en appuyant sur le click molette
(Dans ce mode là tu pourras plus bouger
Ubuntu_Cheval)"

[node name="TutoText6" type="Label" parent="Level"]
offset_left = 2896.0
