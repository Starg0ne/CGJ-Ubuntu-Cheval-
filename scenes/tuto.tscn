offset_right = 3870.0
offset_bottom = 166.0
text = "Tu peux cliquer sur une platforme
pour qu'Ubuntu_Cheval lance son grappin 
puis se déplace avec !"

[node name="TutoText8" type="Label" parent="Level"]
